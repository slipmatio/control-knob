    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "lint": "oxlint . --fix -D correctness --ignore-path .gitignore && eslint \"src/**/*.{ts,vue}\" --concurrency=auto",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint \"src/**/*.{ts,vue}\" --concurrency=auto",
    "fmt": "oxfmt .",
    "ts": "vue-tsc --noEmit",
    "qa": "pnpm fmt && pnpm lint && pnpm ts && pnpm test:run"
  },
  "devDependencies": {
    "@playwright/experimental-ct-vue": "^1.60.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/eslint-plugin": "^1.6.19",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
