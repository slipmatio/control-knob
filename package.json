    "eslint-plugin-oxlint": "^1.68.0",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.10.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.68.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8",
    "vue": "^3.5.35",
    "vue-tsc": "^3.3.3"
  }
